<div class="mb-4">
    <a href="/admin/services" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Services</a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Availability: <%= service.name %></h2>
    <button class="btn btn-palme" data-bs-toggle="modal" data-bs-target="#addSlotModal">
        <i class="bi bi-plus-lg me-2"></i> Add Availability
    </button>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Date</th>
                                <th>Available Time Slots</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (service.availableSlots && service.availableSlots.length > 0) { %>
                                <% service.availableSlots.sort((a,b) => new Date(a.date) - new Date(b.date)).forEach(day => { %>
                                <tr>
                                    <td class="ps-4 fw-bold"><%= day.date %></td>
                                    <td>
                                        <% day.slots.forEach(slot => { %>
                                            <span class="badge bg-light text-dark border me-1"><%= slot %></span>
                                        <% }) %>
                                    </td>
                                    <td class="text-end pe-4">
                                        <form action="/admin/services/<%= service.id %>/slots/delete" method="POST" onsubmit="return confirm('Remove all slots for this date?')">
                                            <input type="hidden" name="date" value="<%= day.date %>">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">No availability added yet.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-light border-0">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i> Instructions</h6>
                <ul class="small text-muted ps-3">
                    <li class="mb-2">Click <strong>Add Availability</strong> to open the calendar.</li>
                    <li class="mb-2">Enter time slots separated by commas (e.g. 10:00AM, 12:30PM, 03:00PM).</li>
                    <li>To block a date, simply remove it from this list.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Slot Modal -->
<div class="modal fade" id="addSlotModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/admin/services/<%= service.id %>/slots" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Set Availability</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Date</label>
                        <input type="date" name="date" class="form-control" required min="<%= new Date().toISOString().split('T')[0] %>">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Available Times (Comma separated)</label>
                        <textarea name="slots" class="form-control" rows="3" placeholder="10:00AM, 11:00AM, 02:00PM" required></textarea>
                        <div class="form-text">Example: 09:00AM, 11:30AM, 03:00PM, 06:00PM</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-palme">Save Availability</button>
                </div>
            </form>
        </div>
    </div>
</div>
