<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Service Categories</h2>
    <button class="btn btn-palme" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
        <i class="bi bi-plus-lg me-2"></i> Add Category
    </button>
</div>

<div class="row g-4">
    <% categories.forEach(cat => { %>
    <div class="col-md-4">
        <div class="card overflow-hidden h-100">
            <img src="<%= cat.image %>" class="card-img-top" style="height: 180px; object-fit: cover;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="card-title mb-0"><%= cat.name %></h5>
                    <span class="badge bg-sage-green text-white" style="background-color: #4A6741;"><%= cat._count.services %> Services</span>
                </div>
                <p class="card-text text-muted small mb-4" style="height: 60px; overflow: hidden;"><%= cat.description %></p>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary w-100" 
                        data-bs-toggle="modal" 
                        data-bs-target="#editCategoryModal<%= cat.id %>">
                        Edit
                    </button>
                    <form action="/admin/categories/<%= cat.id %>/delete" method="POST" onsubmit="return confirm('Delete this category?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Category Modal -->
    <div class="modal fade" id="editCategoryModal<%= cat.id %>" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/admin/categories/<%= cat.id %>/edit" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Category</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Category Name</label>
                            <input type="text" name="name" class="form-control" value="<%= cat.name %>" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Image URL</label>
                            <input type="text" name="image" class="form-control" value="<%= cat.image %>" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="description" class="form-control" rows="3" required><%= cat.description %></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-palme">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <% }) %>
</div>

<!-- Add Category Modal -->
<div class="modal fade" id="addCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/admin/categories" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Category</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Category Name</label>
                        <input type="text" name="name" class="form-control" placeholder="e.g. Nails, Facial" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Image URL</label>
                        <input type="text" name="image" class="form-control" placeholder="https://..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Brief description of the category" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-palme">Create Category</button>
                </div>
            </form>
        </div>
    </div>
</div>
