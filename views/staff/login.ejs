<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Palme Staff | Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --sage-green: #4A6741;
        }
        body {
            background-color: #f4f7f6;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: white;
            padding: 2.5rem;
            border-radius: 20px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        }
        .btn-login {
            background: var(--sage-green);
            color: white;
            border-radius: 10px;
            padding: 0.8rem;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <h2 class="text-center mb-4" style="color: var(--sage-green); font-weight: 800;">PALME STAFF</h2>
        <p class="text-center text-muted mb-4">Therapist & Driver Portal</p>

        <% if (locals.error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/staff/login" method="POST">
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" placeholder="staff@palme.com" required>
            </div>
            <div class="mb-4">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-login w-100">Login to Dashboard</button>
        </form>
    </div>
</body>
</html>
