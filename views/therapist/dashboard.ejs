<h1 class="h3 mb-4">Assigned Appointments</h1>

<% if (assignments.length === 0) { %>
    <div class="alert alert-info">No appointments assigned yet.</div>
<% } %>

<% assignments.forEach(apt => { %>
    <div class="card p-3 mb-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="mb-0"><%= apt.service.name %></h5>
                    <span class="badge bg-<%= apt.status === 'completed' ? 'success' : 'primary' %> bg-opacity-10 text-<%= apt.status === 'completed' ? 'success' : 'primary' %>">
                        <%= apt.status.replace(/_/g, ' ').toUpperCase() %>
                    </span>
                </div>
                <p class="text-muted small mb-0"><%= apt.date %> at <%= apt.time %> (<%= apt.selectedDuration %>)</p>
                <hr class="my-3">
                <div class="small">
                    <div class="mb-1"><strong><i class="bi bi-person"></i> Customer:</strong> <%= apt.user.name %></div>
                    <div class="mb-1"><strong><i class="bi bi-telephone"></i> Phone:</strong> <%= apt.user.phone %></div>
                    <div class="mb-1"><strong><i class="bi bi-car-front"></i> Driver:</strong> 
                        <% if (apt.driver) { %>
                            <%= apt.driver.name %> 
                            <% if (apt.status === 'arrived') { %>
                                <span class="text-success ms-2"><i class="bi bi-check-circle-fill"></i> Arrived!</span>
                            <% } else if (apt.status === 'on_the_way') { %>
                                <span class="text-warning ms-2"><i class="bi bi-clock-history"></i> On the way...</span>
                            <% } %>
                        <% } else { %>
                            <span class="text-danger">None Assigned</span>
                        <% } %>
                    </div>
                </div>
            </div>
            <div class="col-md-6 text-md-end mt-4 mt-md-0">
                <% if (apt.status === 'arrived') { %>
                    <form action="/therapist/appointments/<%= apt.id %>/status" method="POST">
                        <input type="hidden" name="status" value="in_progress">
                        <button type="submit" class="btn btn-primary btn-status w-100 py-3">
                            <i class="bi bi-play-fill me-2"></i> START SESSION
                        </button>
                    </form>
                <% } else if (apt.status === 'in_progress') { %>
                    <form action="/therapist/appointments/<%= apt.id %>/status" method="POST">
                        <input type="hidden" name="status" value="completed">
                        <button type="submit" class="btn btn-success btn-status w-100 py-3">
                            <i class="bi bi-check-lg me-2"></i> MARK AS COMPLETED
                        </button>
                    </form>
                <% } else if (apt.status === 'completed') { %>
                    <button class="btn btn-outline-success w-100 py-3" disabled>
                        <i class="bi bi-check-all me-2"></i> SESSION FINISHED
                    </button>
                <% } else { %>
                    <div class="bg-light p-3 rounded-3 text-center border">
                        <p class="text-muted small mb-0">
                            <i class="bi bi-hourglass-split me-2"></i> 
                            Waiting for Driver to arrive at destination...
                        </p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
<% }) %>
